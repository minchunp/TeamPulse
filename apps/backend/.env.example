# Port & Environment
PORT=5001
NODE_ENV=development

# Database & Cache
MONGO_URI=mongodb://localhost:27017/teampulse
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_ACCESS_SECRET=supersecretaccesstokensecretkeyshouldbelongandcomplex
JWT_REFRESH_SECRET=supersecretrefreshtokensecretkeyshouldbelongandcomplex

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=google_client_id_placeholder
GOOGLE_CLIENT_SECRET=google_client_secret_placeholder
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=github_client_id_placeholder
GITHUB_CLIENT_SECRET=github_client_secret_placeholder
GITHUB_CALLBACK_URL=http://localhost:5001/api/auth/github/callback
