# ================================================================
# Server .gitignore — BESUE Badminton Finance
# ================================================================

# Dependencies
node_modules/

# Build output
dist/

# ================================================================
# Environment variables — NEVER commit .env files with secrets!
# ================================================================
.env
.env.*
# Cho phép file mẫu (không chứa secret thật)
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS generated
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# TypeScript incremental build info
*.tsbuildinfo